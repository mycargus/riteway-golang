{
  "permissions": {
    "allow": [
      "WebFetch(domain:*)",
      "Bash(go get:*)",
      "Bash(gofmt:*)",
      "Bash(go mod:*)",
      "Bash(make check:*)",
      "Bash(go test:*)",
      "Bash(bash scripts/test-release.sh 2>&1)",
      "Bash(bash .claude/hooks/block-publish_test.sh 2>&1)",
      "Bash(git push:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-publish.sh"
          }
        ]
      }
    ]
  }
}
